LFI_DATA_DIR=./data
LFI_DB_PATH=./data/local_db/finance_dashboard.db
# Optional: SHA-256 hash of the local app password
LFI_APP_PASSWORD_HASH=
# Optional plain password for first local setup. Prefer the hash in real use.
LFI_APP_PASSWORD=
# Optional absolute path to a local sentence-transformer model directory.
LFI_LOCAL_EMBEDDING_MODEL_PATH=
# Optional local-only LLM via Ollama. The app accepts localhost URLs only.
LFI_LOCAL_LLM_PROVIDER=
LFI_OLLAMA_BASE_URL=http://127.0.0.1:11434
LFI_OLLAMA_MODEL=qwen2.5:7b-instruct
